# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ──────────────────────────────────────────────
# Integração IXCSoft
# Documentação: https://wikiapiprovedor.ixcsoft.com.br
# ──────────────────────────────────────────────

# URL base do servidor IXC da empresa (sem barra final)
VITE_IXC_BASE_URL=https://ixc.suaempresa.com.br

# Token gerado em: Configurações > Usuários > Usuário > Token de acesso
# Formato: "Basic <base64(usuario:senha)>"   OU   o token direto gerado pelo painel
VITE_IXC_TOKEN=Basic dXN1YXJpbzpzZW5oYQ==

# (Opcional) Nome do campo de status no JSON retornado pela API do contrato.
# Padrão "status_internet" — só altere se sua versão do IXC usar campo diferente.
# VITE_IXC_CAMPO_STATUS_CONTRATO=status_internet
